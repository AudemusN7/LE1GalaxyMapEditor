<Application x:Class="LE1GalaxyMapEditor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LE1GalaxyMapEditor.Converters"
             xmlns:viewModels="clr-namespace:LE1GalaxyMapEditor.ViewModels"
             xmlns:views="clr-namespace:LE1GalaxyMapEditor.Views">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0A1018" />
        <SolidColorBrush x:Key="PanelBrush" Color="#101A25" />
        <SolidColorBrush x:Key="PanelRaisedBrush" Color="#162433" />
        <SolidColorBrush x:Key="BorderBrush" Color="#2A3A49" />
        <SolidColorBrush x:Key="TextBrush" Color="#E8F0F5" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#8FA2B2" />
        <SolidColorBrush x:Key="AccentBrush" Color="#47B4D5" />
        <SolidColorBrush x:Key="AccentDimBrush" Color="#243E4B" />
        <SolidColorBrush x:Key="DangerBrush" Color="#ED5665" />
        <SolidColorBrush x:Key="WarningBrush" Color="#E4AE56" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#29485B" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#213B4B" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#E8F0F5" />

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <converters:PlanetGlyphConverter x:Key="PlanetGlyphConverter" />
        <converters:PlanetBrushConverter x:Key="PlanetBrushConverter" />
        <converters:ObjectScaleConverter x:Key="ObjectScaleConverter" />
        <converters:ModuleColorBrushConverter x:Key="ModuleColorBrushConverter" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#172532" />
            <Setter Property="BorderBrush" Value="#496477" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,5" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#0C151E" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentDimBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#0C151E" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Shell" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2" IsHitTestVisible="False" />
                            <ContentPresenter Margin="7,4,30,4" VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" IsHitTestVisible="False" />
                            <ToggleButton Focusable="False" HorizontalAlignment="Stretch" Background="Transparent" BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <!-- The transparent Grid keeps the complete ComboBox clickable.
                                             Only ArrowHover may paint above the collapsed label. -->
                                        <Grid Background="Transparent">
                                            <Border x:Name="ArrowHover"
                                                    Width="28"
                                                    HorizontalAlignment="Right"
                                                    Background="Transparent">
                                                <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#A9BBC7"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ArrowHover" Property="Background" Value="#142737" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="ArrowHover" Property="Background" Value="#203A4B" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True" Focusable="False" IsOpen="{TemplateBinding IsDropDownOpen}" PopupAnimation="Fade">
                                <Border Background="#101C27" BorderBrush="#496477" BorderThickness="1" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" MaxHeight="320">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"><ItemsPresenter /></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True"><Setter TargetName="Shell" Property="BorderBrush" Value="{StaticResource AccentBrush}"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Shell" Property="Opacity" Value="0.45"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#172532" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Template">
                <Setter.Value><ControlTemplate TargetType="ComboBoxItem"><Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"><TextBlock x:Name="ItemText" Text="{Binding}" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsSelected" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="#203A4B"/><Setter TargetName="ItemText" Property="Foreground" Value="#FFFFFF"/></Trigger><Trigger Property="IsHighlighted" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="#355E75"/><Setter TargetName="ItemText" Property="Foreground" Value="#FFFFFF"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.42"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#29485B" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#0C151E" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#101C27" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#203A4B" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#29485B" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#0B131B" />
            <Setter Property="Foreground" Value="#496477" />
            <Setter Property="MinWidth" Value="12" />
            <Setter Property="MinHeight" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Orientation="{TemplateBinding Orientation}">
                                <Track.DecreaseRepeatButton><RepeatButton x:Name="DecreaseButton" Command="ScrollBar.PageUpCommand" Background="Transparent" BorderThickness="0"/></Track.DecreaseRepeatButton>
                                <Track.Thumb><Thumb><Thumb.Template><ControlTemplate TargetType="Thumb"><Border x:Name="ThumbBorder" Background="#496477" CornerRadius="5" Margin="2"/><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ThumbBorder" Property="Background" Value="#68A5C0"/></Trigger><Trigger Property="IsDragging" Value="True"><Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource AccentBrush}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Thumb.Template></Thumb></Track.Thumb>
                                <Track.IncreaseRepeatButton><RepeatButton x:Name="IncreaseButton" Command="ScrollBar.PageDownCommand" Background="Transparent" BorderThickness="0"/></Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal"><Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/><Setter TargetName="DecreaseButton" Property="Command" Value="ScrollBar.PageLeftCommand"/><Setter TargetName="IncreaseButton" Property="Command" Value="ScrollBar.PageRightCommand"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical"><Setter Property="Width" Value="12"/><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="VerticalAlignment" Value="Stretch"/></Trigger>
                <Trigger Property="Orientation" Value="Horizontal"><Setter Property="Height" Value="12"/><Setter Property="HorizontalAlignment" Value="Stretch"/><Setter Property="VerticalAlignment" Value="Bottom"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/><Setter Property="Background" Value="#111D28"/><Setter Property="BorderBrush" Value="#496477"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="3"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ContextMenu"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}"><StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/></Border></ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/><Setter Property="Background" Value="Transparent"/><Setter Property="Padding" Value="11,6"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="MenuItem"><Border x:Name="MenuBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="2"><ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/></Border><ControlTemplate.Triggers><Trigger Property="IsHighlighted" Value="True"><Setter TargetName="MenuBorder" Property="Background" Value="#29485B"/><Setter Property="Foreground" Value="White"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Foreground" Value="#647784"/><Setter TargetName="MenuBorder" Property="Background" Value="Transparent"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style TargetType="Separator"><Setter Property="Background" Value="#2A3A49"/><Setter Property="Height" Value="1"/><Setter Property="Margin" Value="0,2"/><Setter Property="HorizontalAlignment" Value="Stretch"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Separator"><Border Background="{TemplateBinding Background}" Height="{TemplateBinding Height}"/></ControlTemplate></Setter.Value></Setter></Style>
        <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator"><Setter Property="Background" Value="#2A3A49"/><Setter Property="Height" Value="1"/><Setter Property="Margin" Value="0,2"/><Setter Property="HorizontalAlignment" Value="Stretch"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Separator"><Border Background="{TemplateBinding Background}" Height="1" HorizontalAlignment="Stretch"/></ControlTemplate></Setter.Value></Setter></Style>

        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#203547" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#142B3A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource ChromeButtonStyle}" />

        <Style x:Key="BreadcrumbButtonStyle" TargetType="Button" BasedOn="{StaticResource ChromeButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="5,3" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <DataTemplate DataType="{x:Type viewModels:GalaxyViewModel}">
            <views:GalaxyView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ClusterViewModel}">
            <views:ClusterView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SystemViewModel}">
            <views:SystemView />
        </DataTemplate>
    </Application.Resources>
</Application>
