<UserControl x:Class="LE1GalaxyMapEditor.Views.ClusterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LE1GalaxyMapEditor.Controls"
             Background="Transparent">
    <Grid ClipToBounds="False">
        <Border>
            <Border.Background>
                <RadialGradientBrush Center="0.45,0.48" GradientOrigin="0.35,0.42" RadiusX="0.88" RadiusY="0.82">
                    <GradientStop Color="#24364B" Offset="0" />
                    <GradientStop Color="#1B2638" Offset="0.34" />
                    <GradientStop Color="#101520" Offset="0.7" />
                    <GradientStop Color="#070A10" Offset="1" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <Image Source="{Binding BackgroundTexture}"
               Stretch="Fill"
               IsHitTestVisible="False"
               RenderOptions.BitmapScalingMode="HighQuality" />

        <ItemsControl ItemsSource="{Binding Systems}" ClipToBounds="False">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <controls:NormalizedCanvas ClipToBounds="False" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="controls:NormalizedCanvas.X" Value="{Binding Item.X}" />
                    <Setter Property="controls:NormalizedCanvas.Y" Value="{Binding Item.Y}" />
                    <Setter Property="controls:NormalizedCanvas.AnchorY" Value="25" />
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            MouseDoubleClick="System_OnMouseDoubleClick"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="2"
                            ToolTip="Double-click to open this System">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Clone System…" Command="{Binding CloneCommand}"/>
                                <MenuItem Header="Move to Cluster…" Command="{Binding MoveCommand}"/>
                                <Separator/>
                                <MenuItem Header="Delete System…" Command="{Binding DeleteCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <Button.Template>
                            <ControlTemplate TargetType="Button"><ContentPresenter /></ControlTemplate>
                        </Button.Template>
                        <StackPanel Width="155">
                            <Grid Width="50" Height="50" HorizontalAlignment="Center"
                                  RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <ScaleTransform ScaleX="{Binding Item.Scale, Converter={StaticResource ObjectScaleConverter}}"
                                                    ScaleY="{Binding Item.Scale, Converter={StaticResource ObjectScaleConverter}}" />
                                </Grid.RenderTransform>
                                <Ellipse x:Name="Glow"
                                         Fill="{Binding ModuleColor, Converter={StaticResource ModuleColorBrushConverter}}"
                                         Opacity="0.20"
                                         Width="44"
                                         Height="44" />
                                <Ellipse x:Name="OuterRing"
                                         Stroke="{Binding ModuleColor, Converter={StaticResource ModuleColorBrushConverter}}"
                                         StrokeThickness="1"
                                         Opacity="0.52"
                                         Width="30"
                                         Height="30" />
                                <Ellipse x:Name="MarkerRing"
                                         Fill="#14070D12"
                                         Stroke="{Binding ModuleColor, Converter={StaticResource ModuleColorBrushConverter}}"
                                         StrokeThickness="2"
                                         Width="20"
                                         Height="20" />
                                <Ellipse x:Name="MarkerDot"
                                         Fill="{Binding ModuleColor, Converter={StaticResource ModuleColorBrushConverter}}"
                                         Width="5"
                                         Height="5" />
                            </Grid>
                            <Border x:Name="LabelBorder" Background="#BD0A1018" CornerRadius="2" Padding="5,2" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Button>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="OuterRing" Property="Stroke" Value="#F2A33A" />
                            <Setter TargetName="MarkerRing" Property="Stroke" Value="#F2A33A" />
                            <Setter TargetName="MarkerRing" Property="Fill" Value="#24F2A33A" />
                            <Setter TargetName="MarkerDot" Property="Fill" Value="#FFD27A" />
                            <Setter TargetName="Glow" Property="Fill" Value="#42F2A33A" />
                            <Setter TargetName="LabelBorder" Property="Background" Value="#E24A321B" />
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16" Background="#AA0A1018" BorderBrush="#324655" BorderThickness="1" CornerRadius="3" Padding="10,7" IsHitTestVisible="False">
            <StackPanel>
                <TextBlock Text="CLUSTER VIEW" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="Bold" />
                <TextBlock Text="{Binding Cluster.DisplayName}" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0" />
                <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,2,0,0">
                    <Run Text="{Binding Systems.Count, Mode=OneWay}" />
                    <Run Text=" systems  •  CSV-linked background" />
                </TextBlock>
            </StackPanel>
        </Border>

        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12" Background="#880A1018" CornerRadius="2" Padding="8,4" IsHitTestVisible="False">
            <TextBlock Text="{Binding Cluster.Background, StringFormat=Background: {0}}" Foreground="#667C8B" FontSize="9" />
        </Border>
    </Grid>
</UserControl>
