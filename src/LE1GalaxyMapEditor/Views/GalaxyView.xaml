<UserControl x:Class="LE1GalaxyMapEditor.Views.GalaxyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LE1GalaxyMapEditor.Controls"
             Background="Transparent">
    <Grid ClipToBounds="False">
        <Border>
            <Border.Background>
                <RadialGradientBrush Center="0.46,0.5" GradientOrigin="0.43,0.5" RadiusX="0.78" RadiusY="0.72">
                    <GradientStop Color="#24313D" Offset="0" />
                    <GradientStop Color="#15232E" Offset="0.24" />
                    <GradientStop Color="#10131C" Offset="0.53" />
                    <GradientStop Color="#05070C" Offset="1" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <Image Source="{Binding BackgroundTexture}"
               Stretch="Fill"
               IsHitTestVisible="False"
               RenderOptions.BitmapScalingMode="HighQuality" />

        <controls:RelayLayer Connections="{Binding Relays}"
                             RefreshToken="{Binding RefreshToken}"
                             IsHitTestVisible="False" />

        <ItemsControl ItemsSource="{Binding Clusters}" ClipToBounds="False">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <controls:NormalizedCanvas ClipToBounds="False" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="controls:NormalizedCanvas.X" Value="{Binding Item.X}" />
                    <Setter Property="controls:NormalizedCanvas.Y" Value="{Binding Item.Y}" />
                    <Setter Property="controls:NormalizedCanvas.AnchorY" Value="21" />
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            MouseDoubleClick="Cluster_OnMouseDoubleClick"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="2"
                            ToolTip="Double-click to open this Cluster">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Clone Cluster…" Command="{Binding CloneCommand}"/><Separator/><MenuItem Header="Delete Cluster…" Command="{Binding DeleteCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Width="150">
                            <Grid Width="42" Height="42" HorizontalAlignment="Center">
                                <Ellipse x:Name="Glow"
                                         Fill="{Binding ModuleColor, Converter={StaticResource ModuleColorBrushConverter}}"
                                         Opacity="0.20"
                                         Width="42"
                                         Height="42" />
                                <Ellipse x:Name="MarkerRing"
                                         Fill="#14070D12"
                                         Stroke="{Binding ModuleColor, Converter={StaticResource ModuleColorBrushConverter}}"
                                         StrokeThickness="2"
                                         Width="22"
                                         Height="22" />
                                <Ellipse x:Name="MarkerDot"
                                         Fill="{Binding ModuleColor, Converter={StaticResource ModuleColorBrushConverter}}"
                                         Width="5"
                                         Height="5" />
                            </Grid>
                            <Border x:Name="LabelBorder" Background="#BD0A1018" CornerRadius="2" Padding="5,2" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}" FontSize="11" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Panel.ZIndex" Value="20" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="MarkerRing" Property="Stroke" Value="#F2A33A" />
                            <Setter TargetName="MarkerRing" Property="Fill" Value="#24F2A33A" />
                            <Setter TargetName="MarkerDot" Property="Fill" Value="#FFD27A" />
                            <Setter TargetName="Glow" Property="Fill" Value="#42F2A33A" />
                            <Setter TargetName="LabelBorder" Property="Background" Value="#E24A321B" />
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16" Background="#AA0A1018" BorderBrush="#324655" BorderThickness="1" CornerRadius="3" Padding="10,7" IsHitTestVisible="False">
            <StackPanel>
                <TextBlock Text="GALAXY VIEW" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="Bold" />
                <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,3,0,0">
                    <Run Text="{Binding Clusters.Count, Mode=OneWay}" />
                    <Run Text=" clusters  •  " />
                    <Run Text="{Binding ResolvedRelayCount, Mode=OneWay}" />
                    <Run Text=" visible relays" />
                </TextBlock>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
