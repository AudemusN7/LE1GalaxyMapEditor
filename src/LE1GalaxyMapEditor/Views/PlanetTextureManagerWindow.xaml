<Window x:Class="LE1GalaxyMapEditor.Views.PlanetTextureManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage linked Planet textures" Width="680" Height="470"
        MinWidth="560" MinHeight="380" WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}" Foreground="{StaticResource TextBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Linked textures are stored in module metadata. Missing preview files are excluded from material menus and randomisation until relinked or removed."
                   TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}"/>

        <ListBox x:Name="TextureList" Grid.Row="1" Margin="0,14,0,12"
                 ItemsSource="{Binding}" HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="7,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="190"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding InMemoryPath}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,3,0,0">
                                <Run Text="{Binding ModuleName}"/><Run Text=" ["/><Run Text="{Binding ModuleTag}"/><Run Text="] · "/><Run Text="{Binding Categories}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding ReferenceDetail}" Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding Availability}" HorizontalAlignment="Right"
                                   VerticalAlignment="Center" Foreground="{StaticResource WarningBrush}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock x:Name="ValidationText" Grid.Row="2" Foreground="{StaticResource WarningBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,10"/>

        <Grid Grid.Row="3">
            <TextBlock Text="Unlinking removes the dropdown/randomiser relationship. Existing Planet values and committed preview files are left untouched."
                       Foreground="{StaticResource MutedTextBrush}" FontSize="10" TextWrapping="Wrap"
                       VerticalAlignment="Center" MaxWidth="400" HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Close" IsCancel="True" Padding="14,7" Margin="0,0,8,0"/>
                <Button Content="Unlink selected" IsDefault="True" Padding="16,7"
                        IsEnabled="{Binding SelectedItem.CanUnlink, ElementName=TextureList}"
                        Click="UnlinkButton_OnClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
