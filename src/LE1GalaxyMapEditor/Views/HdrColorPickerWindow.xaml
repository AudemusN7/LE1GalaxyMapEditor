<Window x:Class="LE1GalaxyMapEditor.Views.HdrColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:LE1GalaxyMapEditor.Controls"
        Title="Choose HDR material colour" Width="540" Height="430" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource AppBackgroundBrush}" Foreground="{StaticResource TextBrush}">
    <Grid Margin="20">
        <Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <controls:ColorWheelControl x:Name="Wheel" Width="230" Height="230" ColorChanged="Wheel_OnColorChanged"/>
        <StackPanel Grid.Column="1" Margin="18,0,0,0">
            <TextBlock Text="HDR MATERIAL COLOUR" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
            <Border x:Name="Preview" Height="44" Margin="0,12,0,13" BorderBrush="#8AA0AE" BorderThickness="1"/>
            <TextBlock Text="Intensity" Foreground="{StaticResource MutedTextBrush}"/>
            <Grid Margin="0,4,0,12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="72"/></Grid.ColumnDefinitions>
                <Slider x:Name="IntensitySlider" Minimum="0" Maximum="10" ValueChanged="IntensitySlider_OnValueChanged"/>
                <TextBox x:Name="IntensityBox" Grid.Column="1" Margin="7,0,0,0" TextChanged="IntensityBox_OnTextChanged" HorizontalContentAlignment="Right"/>
            </Grid>
            <TextBlock Text="RGBA values" Foreground="{StaticResource MutedTextBrush}"/>
            <UniformGrid Columns="4" Margin="0,4,0,0">
                <TextBox x:Name="RBox" ToolTip="Red" TextChanged="Components_OnTextChanged" Margin="0,0,4,0" HorizontalContentAlignment="Right"/>
                <TextBox x:Name="GBox" ToolTip="Green" TextChanged="Components_OnTextChanged" Margin="0,0,4,0" HorizontalContentAlignment="Right"/>
                <TextBox x:Name="BBox" ToolTip="Blue" TextChanged="Components_OnTextChanged" Margin="0,0,4,0" HorizontalContentAlignment="Right"/>
                <TextBox x:Name="ABox" ToolTip="Alpha" TextChanged="Components_OnTextChanged" HorizontalContentAlignment="Right"/>
            </UniformGrid>
            <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" FontSize="10" Margin="0,8,0,0" TextWrapping="Wrap"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" IsCancel="True" Padding="14,7" Margin="0,0,8,0"/>
            <Button Content="Use colour" IsDefault="True" Padding="16,7" Click="Use_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
