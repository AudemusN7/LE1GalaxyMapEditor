<Window x:Class="LE1GalaxyMapEditor.Views.MoveDestinationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Move galaxy-map entry" Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#101820" Foreground="#E5EEF5">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="HeadingText" Foreground="#62BEEA" FontWeight="Bold"/>
            <TextBlock x:Name="SummaryText" Margin="0,8,0,18" TextWrapping="Wrap" Foreground="#91A4B2"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Destination" Margin="0,0,0,6"/>
            <ComboBox x:Name="DestinationBox" MinHeight="30" SelectionChanged="Destination_OnSelectionChanged"/>
        </StackPanel>

        <Border Grid.Row="2" Margin="0,16,0,16" Padding="12" Background="#17232E" BorderBrush="#2A4356" BorderThickness="1">
            <StackPanel>
                <TextBlock x:Name="DestinationDetailText" TextWrapping="Wrap"/>
                <TextBlock x:Name="LabelResultText" Margin="0,8,0,0" Foreground="#91A4B2" TextWrapping="Wrap"/>
                <TextBlock Margin="0,8,0,0" Foreground="#91A4B2" TextWrapping="Wrap"
                           Text="The row ID and map coordinates stay unchanged. ActiveWorld and linked PlotPlanet codes are recalculated automatically."/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="85" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="Move" Width="85" IsDefault="True" Click="Move_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
