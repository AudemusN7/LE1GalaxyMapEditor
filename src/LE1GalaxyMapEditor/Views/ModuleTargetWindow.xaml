<Window x:Class="LE1GalaxyMapEditor.Views.ModuleTargetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:LE1GalaxyMapEditor.Models"
        Title="Choose edit module"
        Width="460"
        Height="390"
        MinWidth="400"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="CHOOSE EDIT MODULE" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" />
            <TextBlock Text="The selected BASEGAME row will be copied into this module as a complete same-ID override."
                       Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,6,0,0" />
        </StackPanel>

        <ListBox x:Name="ModuleList"
                 Grid.Row="1"
                 BorderBrush="{StaticResource BorderBrush}"
                 Background="#0C151E"
                 MouseDoubleClick="ModuleList_OnMouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:GalaxyMapModule}">
                    <Grid Margin="7,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="9" Height="9"
                                 Fill="{Binding Color, Converter={StaticResource ModuleColorBrushConverter}}"
                                 Margin="0,0,9,0" />
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Tag}" Foreground="{StaticResource MutedTextBrush}" FontSize="10" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding LoadOrder, StringFormat=Priority {0}}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="18,0,3,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,13,0,0">
            <Button Content="Cancel" IsCancel="True" Style="{StaticResource ChromeButtonStyle}" Margin="0,0,8,0" />
            <Button Content="Use module" IsDefault="True" Click="AcceptButton_OnClick" Style="{StaticResource ChromeButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
