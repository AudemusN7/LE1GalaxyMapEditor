<Window x:Class="LE1GalaxyMapEditor.Views.ModuleSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Galaxy Map Module"
        Width="620"
        Height="650"
        MinWidth="560"
        MinHeight="590"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,17">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock x:Name="HeadingText" Text="CREATE AUTHORING MODULE" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" />
                <TextBlock x:Name="ExplanationText"
                           Margin="0,7,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="The module owns every generated _part CSV. BASEGAME and mounted source modules remain read-only." />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="18,0,0,0">
                <Button x:Name="UnlinkButton"
                        Content="Unlink Module"
                        Visibility="Collapsed"
                        Padding="11,5"
                        Click="UnlinkButton_OnClick"
                        Style="{StaticResource ChromeButtonStyle}" />
                <Button x:Name="ForgetButton"
                        Content="Forget Module"
                        Visibility="Collapsed"
                        Margin="7,0,0,0"
                        Padding="11,5"
                        Foreground="{StaticResource DangerBrush}"
                        Background="#351A20"
                        BorderBrush="#71313D"
                        Click="ForgetButton_OnClick"
                        Style="{StaticResource ChromeButtonStyle}" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="145" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Display name" VerticalAlignment="Center" />
                    <TextBox x:Name="NameBox" Grid.Column="1" Padding="7,5" TextChanged="NameBox_OnTextChanged" />
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="145" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Module tag" VerticalAlignment="Center" />
                    <TextBox x:Name="TagBox" Grid.Column="1" Padding="7,5" CharacterCasing="Upper" TextChanged="TagBox_OnTextChanged" />
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="145" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Map colour" VerticalAlignment="Center" />
                    <ComboBox x:Name="ColorBox" Grid.Column="1" Padding="6,4" />
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="145" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Mount priority" VerticalAlignment="Center" />
                    <TextBox x:Name="LoadOrderBox" Grid.Column="1" Padding="7,5" />
                </Grid>
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="145" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock x:Name="FolderLabel" Text="Parent folder" VerticalAlignment="Center" />
                    <TextBox x:Name="FolderBox" Grid.Column="1" Padding="7,5" />
                    <Button x:Name="BrowseButton" Grid.Column="2" Content="Browse…" Margin="7,0,0,0" Padding="11,5" Click="BrowseButton_OnClick" Style="{StaticResource ChromeButtonStyle}" />
                </Grid>

                <StackPanel x:Name="PccSettingsPanel" Visibility="Collapsed" Margin="0,0,0,18">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="145" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Text="TLK locale" VerticalAlignment="Center" />
                        <ComboBox x:Name="TlkLocaleBox" Grid.Column="1" Padding="6,4" />
                    </Grid>
                    <TextBlock Text="READ-ONLY RESOURCE PCCS" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" />
                    <TextBlock Margin="0,4,0,7" Foreground="{StaticResource MutedTextBrush}" FontSize="10" TextWrapping="Wrap"
                               Text="Register one or more PCCs from this DLC to expose their Texture2D resources. These packages are never modified." />
                    <ListBox x:Name="ResourcePackageList" Height="72" HorizontalContentAlignment="Stretch" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,7,0,0">
                        <Button Content="Add PCCs" Padding="11,5" Click="AddResourcePackage_OnClick" Style="{StaticResource ChromeButtonStyle}" />
                        <Button Content="Remove" Margin="7,0,0,0" Padding="11,5" Click="RemoveResourcePackage_OnClick" Style="{StaticResource ChromeButtonStyle}" />
                    </StackPanel>
                </StackPanel>

                <Border Background="#111E29" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="12">
                    <StackPanel>
                        <TextBlock Text="RESERVED ROW ID RANGES" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" />
                        <TextBlock Margin="0,4,0,11" Foreground="{StaticResource MutedTextBrush}" FontSize="10" TextWrapping="Wrap"
                                   Text="Ranges are inclusive and separate per table. Leave both fields blank when the module will not create rows in that table. PlotPlanet rows share the Planet range." />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Column="1" Text="Start" Foreground="{StaticResource MutedTextBrush}" FontSize="10" />
                            <TextBlock Grid.Column="3" Text="End" Foreground="{StaticResource MutedTextBrush}" FontSize="10" />

                            <TextBlock Grid.Row="1" Text="Cluster" VerticalAlignment="Center" />
                            <TextBox x:Name="ClusterStartBox" Grid.Row="1" Grid.Column="1" Margin="0,3" Padding="6,4" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="–" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBox x:Name="ClusterEndBox" Grid.Row="1" Grid.Column="3" Margin="0,3" Padding="6,4" />

                            <TextBlock Grid.Row="2" Text="System" VerticalAlignment="Center" />
                            <TextBox x:Name="SystemStartBox" Grid.Row="2" Grid.Column="1" Margin="0,3" Padding="6,4" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="–" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBox x:Name="SystemEndBox" Grid.Row="2" Grid.Column="3" Margin="0,3" Padding="6,4" />

                            <TextBlock Grid.Row="3" Text="Planet / PlotPlanet" VerticalAlignment="Center" />
                            <TextBox x:Name="PlanetStartBox" Grid.Row="3" Grid.Column="1" Margin="0,3" Padding="6,4" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="–" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBox x:Name="PlanetEndBox" Grid.Row="3" Grid.Column="3" Margin="0,3" Padding="6,4" />

                            <TextBlock Grid.Row="4" Text="Map" VerticalAlignment="Center" />
                            <TextBox x:Name="MapStartBox" Grid.Row="4" Grid.Column="1" Margin="0,3" Padding="6,4" />
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="–" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBox x:Name="MapEndBox" Grid.Row="4" Grid.Column="3" Margin="0,3" Padding="6,4" />

                            <TextBlock Grid.Row="5" Text="Relay" VerticalAlignment="Center" />
                            <TextBox x:Name="RelayStartBox" Grid.Row="5" Grid.Column="1" Margin="0,3" Padding="6,4" />
                            <TextBlock Grid.Row="5" Grid.Column="2" Text="–" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBox x:Name="RelayEndBox" Grid.Row="5" Grid.Column="3" Margin="0,3" Padding="6,4" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,17,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,15,0" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="SetActiveButton"
                        Content="Set as Active"
                        Visibility="Collapsed"
                        Click="SetActiveButton_OnClick"
                        Style="{StaticResource ChromeButtonStyle}"
                        Margin="0,0,8,0" />
                <Button Content="Cancel" IsCancel="True" Style="{StaticResource ChromeButtonStyle}" Margin="0,0,8,0" />
                <Button x:Name="AcceptButton" Content="Create module" IsDefault="True" Click="AcceptButton_OnClick" Style="{StaticResource ChromeButtonStyle}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
