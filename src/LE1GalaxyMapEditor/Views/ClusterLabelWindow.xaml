<Window x:Class="LE1GalaxyMapEditor.Views.ClusterLabelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose Cluster label"
        Width="590"
        Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="CHOOSE A GLOBALLY UNIQUE CLUSTER LABEL"
                       Foreground="{StaticResource AccentBrush}"
                       FontSize="11"
                       FontWeight="Bold"/>
            <TextBlock Margin="0,8,0,0"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap"
                       Text="Cluster labels are shared by the entire galaxy map, including every installed mod. Vanilla reserves Cluster01–Cluster21. New module Clusters must use Cluster22–Cluster99."/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,14,0,0"
                Padding="12"
                BorderBrush="{StaticResource WarningBrush}"
                BorderThickness="1"
                CornerRadius="3">
            <TextBlock Foreground="{StaticResource WarningBrush}"
                       TextWrapping="Wrap"
                       Text="Mounted-module checks cannot detect labels used by mods that are not currently open. Coordinate Cluster ranges with other mod authors before release; overlapping labels are incompatible."/>
        </Border>

        <TextBlock Grid.Row="2" Text="Cluster label" Margin="0,16,0,4"/>
        <TextBox x:Name="ClusterLabelBox"
                 Grid.Row="3"
                 Padding="8,6"
                 SelectionBrush="{StaticResource AccentDimBrush}"/>

        <StackPanel Grid.Row="4" Margin="0,10,0,0">
            <TextBlock x:Name="ValidationText"
                       Foreground="{StaticResource DangerBrush}"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"/>
            <TextBlock Text="Labels currently present in mounted modules"
                       Margin="0,10,0,4"
                       FontWeight="SemiBold"/>
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8">
                <ScrollViewer Height="105" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="MountedLabelsText"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" IsCancel="True" Style="{StaticResource ChromeButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="Create Cluster" IsDefault="True" Style="{StaticResource ChromeButtonStyle}" Click="AcceptButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
