<Window x:Class="LE1GalaxyMapEditor.Views.LandableDestinationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:LE1GalaxyMapEditor.Controls"
        Title="Configure landable destination" Width="500" Height="440" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="{StaticResource AppBackgroundBrush}" Foreground="{StaticResource TextBrush}">
    <Grid Margin="22">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="LANDABLE DESTINATION" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/><TextBlock Margin="0,7,0,15" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Text="Create or update the linked Map and the Planet's interaction event."/></StackPanel>
        <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="135"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition Height="44"/><RowDefinition Height="44"/><RowDefinition Height="44"/><RowDefinition Height="44"/><RowDefinition Height="40"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <TextBlock Text="Persistent level" VerticalAlignment="Center"/><TextBox x:Name="MapNameBox" Grid.Column="1" Margin="0,5" Padding="7,5"/>
            <TextBlock Grid.Row="1" Text="Start point" VerticalAlignment="Center"/><TextBox x:Name="StartPointBox" Grid.Row="1" Grid.Column="1" Margin="0,5" Padding="7,5"/>
            <TextBlock Grid.Row="2" Text="Remote event" VerticalAlignment="Center"/><TextBox x:Name="EventBox" Grid.Row="2" Grid.Column="1" Margin="0,5" Padding="7,5"/>
            <TextBlock Grid.Row="3" Text="Use button TLK" VerticalAlignment="Center"/>
            <Grid Grid.Row="3" Grid.Column="1" Margin="0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBox x:Name="ButtonLabelBox" Padding="7,5"/>
                <controls:StrRefLookupControl x:Name="ButtonLabelLookup" Grid.Column="1" Margin="5,0,0,0"
                                              StringRefText="{Binding Text, ElementName=ButtonLabelBox}"/>
            </Grid>
            <CheckBox x:Name="PlotPlanetBox" Grid.Row="4" Grid.ColumnSpan="2" Content="Also create a mirrored PlotPlanet row" VerticalAlignment="Center"/>
            <TextBlock x:Name="ErrorText" Grid.Row="5" Grid.ColumnSpan="2" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap"/>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Cancel" Width="88" Margin="0,0,8,0" IsCancel="True" Style="{StaticResource ChromeButtonStyle}"/><Button Content="Apply" Width="88" IsDefault="True" Click="Apply_OnClick" Style="{StaticResource ChromeButtonStyle}"/></StackPanel>
    </Grid>
</Window>
