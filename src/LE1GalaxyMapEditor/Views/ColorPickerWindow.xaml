<Window x:Class="LE1GalaxyMapEditor.Views.ColorPickerWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:controls="clr-namespace:LE1GalaxyMapEditor.Controls"
        Title="Packed colour picker" Width="490" Height="390" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="#101820" Foreground="#E5EEF5">
    <Grid Margin="20"><Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <controls:ColorWheelControl x:Name="Wheel" Width="230" Height="230" ColorChanged="Wheel_OnColorChanged"/>
        <StackPanel Grid.Column="1" Margin="18,0,0,0">
            <TextBlock Text="32-BIT ARGB COLOUR" Foreground="#62BEEA" FontWeight="Bold"/>
            <Border x:Name="Preview" Height="40" Margin="0,12" BorderBrush="#8AA0AE" BorderThickness="1"/>
            <TextBlock Text="HEX (#AARRGGBB)" Foreground="#91A4B2"/><TextBox x:Name="HexBox" Margin="0,4,0,9"/>
            <UniformGrid Columns="4"><TextBox x:Name="ABox" ToolTip="Alpha"/><TextBox x:Name="RBox" ToolTip="Red"/><TextBox x:Name="GBox" ToolTip="Green"/><TextBox x:Name="BBox" ToolTip="Blue"/></UniformGrid>
            <TextBlock Text="A     R     G     B" Foreground="#91A4B2" FontSize="10" Margin="0,3,0,9"/>
            <Button Content="Apply HEX / RGB values" Click="ApplyFields_OnClick"/>
            <TextBlock x:Name="PackedText" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#91A4B2"/>
            <TextBlock x:Name="ErrorText" Foreground="#FF7D88" TextWrapping="Wrap"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Cancel" Width="85" Margin="0,0,8,0" IsCancel="True"/><Button Content="Use colour" Width="95" IsDefault="True" Click="Use_OnClick"/></StackPanel>
    </Grid>
</Window>
