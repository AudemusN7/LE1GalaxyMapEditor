<UserControl x:Class="LE1GalaxyMapEditor.Controls.StrRefLookupControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <UserControl.Resources>
        <Style x:Key="TlkToggleStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#203547" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#142B3A" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <ToggleButton x:Name="LookupButton" Width="34" Padding="3" Content="TLK"
                      Style="{StaticResource TlkToggleStyle}"
                      ToolTip="Look up this string reference" />
        <Popup IsOpen="{Binding IsChecked, ElementName=LookupButton}"
               PlacementTarget="{Binding ElementName=LookupButton}"
               Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Width="390" MaxHeight="330" Margin="0,4,0,0" Padding="12"
                    Background="#111E29" BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1" CornerRadius="3">
                <StackPanel>
                    <TextBlock x:Name="StateText" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                    <TextBox x:Name="ValueText" Margin="0,8,0,7" Padding="7"
                             IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                             MaxHeight="230" VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled" />
                    <TextBlock x:Name="ContextText" Foreground="{StaticResource MutedTextBrush}"
                               FontSize="10" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
